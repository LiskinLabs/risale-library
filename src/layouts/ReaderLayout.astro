---
import { DesktopControls } from '../components/reader/DesktopControls';
import '../styles/global.css';

interface Props {
	title: string;
	bookTitle?: string;
}

const { title, bookTitle } = Astro.props;
const isBookPage = !!bookTitle;
---

<!doctype html>
<html lang="ru">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class={isBookPage ? "is-reader-layout" : ""} style={!isBookPage ? "min-height: 100vh;" : ""}>

		{/* ── BOOK READER MODE ── */}
		{isBookPage && (
			<div class="reader-layout-wrapper">
				<slot name="left-sidebar" />

				<div class="reader-content-center">
					<slot name="reader-header" />
					<slot name="settings-panel" />
					<main style="flex: 1; padding-bottom: 64px;">
						<div id="reader-container">
							<slot />
						</div>
					</main>
					<slot name="reader-footer" />
				</div>

				<slot name="right-sidebar" />
			</div>
		)}

		{/* ── LIBRARY MODE ── */}
		{!isBookPage && (
			<>
				<header data-tauri-drag-region class="sticky top-0 z-40 w-full glass-panel cursor-default border-b-0 border-x-0" style={`background: var(--glass-bg);`}>
					<div data-tauri-drag-region class="container mx-auto px-4 h-[72px] flex items-center justify-between">
						<div data-tauri-drag-region class="flex items-center gap-2">
							<a href={import.meta.env.BASE_URL} class="flex items-center gap-3 group">
								<div class="w-10 h-10 rounded-xl flex items-center justify-center text-white font-black shadow-[0_2px_10px_rgba(194,65,12,0.4)] transition-transform group-hover:scale-105" style="background: linear-gradient(135deg, var(--accent) 0%, var(--accent-hover) 100%);">RN</div>
								<h1 class="text-xl font-black hidden sm:block tracking-tight" style="color: var(--text-primary); font-family: var(--font-inter);">Рисале-и Нур <span style="color: var(--accent); opacity: 0.9;">Библиотека</span></h1>
							</a>
						</div>
						<div class="flex items-center gap-4">
							<slot name="header-controls" />
							<DesktopControls client:only="react" />
						</div>
					</div>
				</header>

				<main class="container mx-auto px-4 py-8 lg:py-16">
					<slot />
				</main>

				<footer class="py-16 mt-12 glass-panel border-b-0 border-x-0">
					<div class="container mx-auto px-4 text-center">
						<p class="text-base italic mb-2" style="color: var(--text-secondary); font-family: var(--font-literata);">«Слово — это плод размышления, а истина — это дух веры»</p>
						<p class="mt-4 text-sm font-medium tracking-wide uppercase" style="color: var(--text-muted); font-family: var(--font-inter);">© 2026 Многоязычная библиотека трудов Рисале-и Нур</p>
					</div>
				</footer>
			</>
		)}

		<script>
			import { applyReaderSettings } from '../stores/readerStore';
			applyReaderSettings();
		</script>
	</body>
</html>
