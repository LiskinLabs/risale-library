---
import { SettingsBar } from '../components/reader/SettingsBar';
import { CommentaryToggle } from '../components/reader/Commentary';
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="ru">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | Электронная библиотека Рисале-и Нур</title>
	</head>
	<body class="bg-slate-50 dark:bg-slate-950 min-h-screen selection:bg-amber-200 dark:selection:bg-amber-900">
		<!-- Header / Navigation -->
		<header class="sticky top-0 z-40 w-full bg-white/80 dark:bg-slate-900/80 backdrop-blur-md border-b border-slate-200 dark:border-slate-800 shadow-sm">
			<div class="container mx-auto px-4 h-16 flex items-center justify-between">
				<div class="flex items-center gap-2">
					<a href="/" class="flex items-center gap-2 group">
						<div class="w-8 h-8 bg-amber-600 rounded-lg flex items-center justify-center text-white font-bold shadow-md shadow-amber-600/20 group-hover:bg-amber-500 transition-colors">RN</div>
						<h1 class="text-lg font-bold text-slate-800 dark:text-slate-100 hidden sm:block group-hover:text-amber-600 transition-colors">Рисале-и Нур <span class="text-amber-600">Библиотека</span></h1>
					</a>
				</div>
				
				<div class="flex items-center gap-4">
					<CommentaryToggle client:load />
				</div>
			</div>
		</header>

		<!-- Main Content Area -->
		<main class="container mx-auto px-4 py-8 lg:py-16">
			<div id="reader-container" class="transition-all-custom font-reader">
				<slot />
			</div>
		</main>

		<!-- Bottom Floating Settings (Visible on Mobile & Desktop) -->
		<div class="fixed bottom-8 left-1/2 -translate-x-1/2 z-50">
			<SettingsBar client:load />
		</div>

		<footer class="py-12 border-t border-slate-200 dark:border-slate-800 bg-slate-100 dark:bg-slate-900">
			<div class="container mx-auto px-4 text-center">
				<p class="text-slate-500 dark:text-slate-400 text-sm italic">«Слово — это плод размышления, а истина — это дух веры»</p>
				<p class="mt-4 text-xs text-slate-400">© 2026 Многоязычная библиотека трудов Рисале-и Нур</p>
			</div>
		</footer>

		<script>
			import { fontScale } from '../stores/readerStore';
			
			// Subscribe to fontScale and apply it to the container
			fontScale.subscribe((scale) => {
				const container = document.getElementById('reader-container');
				if (container) {
					container.style.fontSize = `${scale}rem`;
				}
			});

			// Simple Dark Mode Support (optional, can be expanded)
			if (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) {
				// document.documentElement.classList.add('dark');
			}
		</script>
	</body>
</html>
