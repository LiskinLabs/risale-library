---
import { DesktopControls } from '../components/reader/DesktopControls';
import '../styles/global.css';

interface Props {
	title: string;
	bookTitle?: string;
}

const { title, bookTitle } = Astro.props;
const isBookPage = !!bookTitle;
---

<!doctype html>
<html lang="ru">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body style="min-height: 100vh;">

		{/* ── BOOK READER MODE ── */}
		{isBookPage && (
			<>
				<slot name="reader-header" />
				<slot name="settings-panel" />
				<main style="padding-top: 52px; padding-bottom: 64px;">
					<div id="reader-container">
						<slot />
					</div>
				</main>
				<slot name="reader-footer" />
			</>
		)}

		{/* ── LIBRARY MODE ── */}
		{!isBookPage && (
			<>
				<header data-tauri-drag-region class="sticky top-0 z-40 w-full backdrop-blur-md shadow-sm cursor-default" style={`background: color-mix(in srgb, var(--bg-page, #fff) 85%, transparent); border-bottom: 1px solid var(--border-color, #e7e5e4);`}>
					<div data-tauri-drag-region class="container mx-auto px-4 h-16 flex items-center justify-between">
						<div data-tauri-drag-region class="flex items-center gap-2">
							<a href={import.meta.env.BASE_URL} class="flex items-center gap-2 group">
								<div class="w-8 h-8 rounded-lg flex items-center justify-center text-white font-bold shadow-md" style="background: var(--accent, #c2410c);">RN</div>
								<h1 class="text-lg font-bold hidden sm:block" style="color: var(--text-primary);">Рисале-и Нур <span style="color: var(--accent, #c2410c);">Библиотека</span></h1>
							</a>
						</div>
						<div class="flex items-center gap-4">
							<slot name="header-controls" />
							<DesktopControls client:only="react" />
						</div>
					</div>
				</header>

				<main class="container mx-auto px-4 py-8 lg:py-16">
					<slot />
				</main>

				<footer class="py-12" style={`border-top: 1px solid var(--border-color, #e7e5e4); background: var(--bg-surface, #f5f5f4);`}>
					<div class="container mx-auto px-4 text-center">
						<p class="text-sm italic" style="color: var(--text-muted);">«Слово — это плод размышления, а истина — это дух веры»</p>
						<p class="mt-4 text-xs" style="color: var(--text-muted);">© 2026 Многоязычная библиотека трудов Рисале-и Нур</p>
					</div>
				</footer>
			</>
		)}

		<script>
			import { applyReaderSettings } from '../stores/readerStore';
			applyReaderSettings();
		</script>
	</body>
</html>
