---
import { getCollection, render } from 'astro:content';
import ReaderLayout from '../../layouts/ReaderLayout.astro';
import { ReaderProgress } from '../../components/reader/ReaderProgress';
import { ReaderHeader } from '../../components/reader/ReaderHeader';
import { SettingsPanel } from '../../components/reader/SettingsPanel';
import { ProgressFooter } from '../../components/reader/ProgressFooter';
import { ReaderSidebar } from '../../components/reader/ReaderSidebar';
import { PageNavigator } from '../../components/reader/PageNavigator';
import { TextSelectionTooltip } from '../../components/reader/TextSelectionTooltip';
import { LugatTooltip } from '../../components/reader/LugatTooltip';

export async function getStaticPaths() {
  const allEntries = await getCollection('risale');
  // Exclude archive fragments — they are excerpts from main books
  return allEntries
    .filter(entry => !entry.id.includes('/archive/'))
    .map(entry => ({
      params: { slug: entry.id },
      props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);

const getPrettyTitle = (slug: string, fallback: string | undefined) => {
  if (fallback && fallback.trim() !== '') return fallback;
  const key = slug.split('/').pop() || '';
  return key.replace(/-/g, ' ').replace(/\b\w/g, l => l.toUpperCase()).trim();
};

const prettyTitle = getPrettyTitle(entry.id, entry.data.title);
const bookLang = entry.id.split('/')[0] || 'ru';
---

<ReaderLayout title={`${prettyTitle} | Рисале-и Нур`} bookTitle={prettyTitle}>

  <!-- Left Sidebar (TOC) -->
  <ReaderSidebar client:only="react" headings={headings} bookTitle={prettyTitle} slot="left-sidebar" />

  <!-- Reader Header -->
  <ReaderHeader 
    client:only="react" 
    slot="reader-header"
    title={prettyTitle}
    backUrl="/"
  />

  <!-- Settings Panel -->
  <SettingsPanel client:only="react" slot="settings-panel" />

  <!-- Page Navigation (Left/Right Arrows + Scroll) -->
  <PageNavigator client:only="react" />

  <!-- Main Reader Content -->
  <article id="book-content" data-pagefind-body data-lang={bookLang} class="reader-page">
    <Content />
  </article>

  <!-- Text Selection Tooltip & TTS -->
  <TextSelectionTooltip client:only="react" />

  <!-- Lugat Tooltip (Floating) -->
  <LugatTooltip client:only="react" />

  <!-- Progress Footer -->
  <ProgressFooter 
    client:only="react" 
    slot="reader-footer"
    chapterName={prettyTitle}
  />

</ReaderLayout>

<ReaderProgress client:only="react" slug={entry.id} />

<script>
  import { applyReaderSettings, bookLanguage, selectedWord, lugatPopupPosition } from '../../stores/readerStore';
  
  // Set book language from article's data-lang attribute
  const articleEl = document.getElementById('book-content');
  const lang = articleEl?.getAttribute('data-lang') || 'ru';
  bookLanguage.set(lang);
  applyReaderSettings();

  // Lugat Interaction Logic
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    const lugatWord = target.closest('.lugat-word');
    
    if (lugatWord) {
      e.preventDefault();
      e.stopPropagation();
      
      const word = lugatWord.getAttribute('data-word') || '';
      const meaning = lugatWord.getAttribute('data-meaning') || '';
      
      const rect = lugatWord.getBoundingClientRect();
      
      selectedWord.set({ word, meaning });
      lugatPopupPosition.set({ 
        x: rect.left + rect.width / 2, 
        y: rect.top 
      });
    }
  });
</script>

<style is:global>
  /* Arabic text overrides for reader */
  .arabic {
    font-family: var(--font-amiri);
    font-size: 1.5em;
    line-height: 2.4;
    color: var(--text-arabic);
    direction: rtl;
    unicode-bidi: isolate;
  }

  /* Ultra-thin auto-hiding scrollbars */
  .scrollbar-thin::-webkit-scrollbar { width: 4px; }
  .scrollbar-thin::-webkit-scrollbar-track { background: transparent; }
  .scrollbar-thin::-webkit-scrollbar-thumb { background-color: var(--border-color); border-radius: 9999px; }

  .reader-sidebar-left,
  .reader-sidebar-right,
  .reader-content-center {
    scrollbar-width: thin;
    scrollbar-color: transparent transparent;
    transition: scrollbar-color 0.3s ease;
  }
  .reader-sidebar-left:hover,
  .reader-sidebar-right:hover,
  .reader-content-center:hover {
    scrollbar-color: color-mix(in srgb, var(--text-muted) 30%, transparent) transparent;
  }

  .reader-sidebar-left::-webkit-scrollbar,
  .reader-sidebar-right::-webkit-scrollbar,
  .reader-content-center::-webkit-scrollbar { width: 4px; }
  .reader-sidebar-left::-webkit-scrollbar-track,
  .reader-sidebar-right::-webkit-scrollbar-track,
  .reader-content-center::-webkit-scrollbar-track { background: transparent; }
  .reader-sidebar-left::-webkit-scrollbar-thumb,
  .reader-sidebar-right::-webkit-scrollbar-thumb,
  .reader-content-center::-webkit-scrollbar-thumb {
    background-color: transparent;
    border-radius: 9999px;
    transition: background-color 0.3s ease;
  }
  .reader-sidebar-left:hover::-webkit-scrollbar-thumb,
  .reader-sidebar-right:hover::-webkit-scrollbar-thumb,
  .reader-content-center:hover::-webkit-scrollbar-thumb { background-color: rgba(0,0,0,0.12); }
  [data-theme="dark"] .reader-sidebar-left:hover::-webkit-scrollbar-thumb,
  [data-theme="dark"] .reader-sidebar-right:hover::-webkit-scrollbar-thumb,
  [data-theme="dark"] .reader-content-center:hover::-webkit-scrollbar-thumb { background-color: rgba(255,255,255,0.1); }
</style>
