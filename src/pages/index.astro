---
import { getCollection } from 'astro:content';
import ReaderLayout from '../layouts/ReaderLayout.astro';
import { HomePersistence } from '../components/home/HomePersistence';
import { LibraryTabs } from '../components/home/LibraryTabs';

// Fetch all books
const allBooks = await getCollection('risale');
console.log('--- DEBUG ALL BOOKS ---', allBooks.length);

const getPrettyTitle = (id: string, fallback: string | undefined) => {
  // If a valid title is in frontmatter, always trust it
  if (fallback && fallback.trim() !== '') return fallback;
  
  // Otherwise gracefully fallback to rendering the filename without extension
  const parts = id.split('/');
  return parts[parts.length - 1].replace('.md', '').replace('.mdx', '').trim();
};

const formatBook = (b: any) => {
  const lang = b.id.split('/')[0];
  return {
    id: b.id,
    title: getPrettyTitle(b.id, b.data.title),
    book: b.data.book,
    lang,
    category: b.data.category || 'other',
    order: b.data.order || 999
  };
};

const libraryData: Record<string, any[]> = {};

allBooks.forEach(b => {
  const formatted = formatBook(b);
  if (!libraryData[formatted.lang]) {
    libraryData[formatted.lang] = [];
  }
  libraryData[formatted.lang].push(formatted);
});

// Sort books per language
Object.keys(libraryData).forEach(lang => {
  if (lang === 'tr') {
    libraryData[lang].sort((a,b) => a.order - b.order);
  } else {
    libraryData[lang].sort((a,b) => a.title.localeCompare(b.title));
  }
});
---

<ReaderLayout title="Главная">
	<div class="mesh-bg absolute inset-0 z-0"></div>
	
	<div class="relative z-10 max-w-7xl mx-auto px-4 py-12 lg:py-24">
		<div class="text-center mb-16 lg:mb-28 glass-panel mx-auto max-w-4xl p-12 lg:p-16 rounded-[2rem]">
			<h1 class="text-5xl lg:text-7xl font-black text-slate-800 dark:text-white mb-6 tracking-tighter leading-tight" style="font-family: var(--font-inter);">
				Рисале-и Нур
				<span class="block mt-2 text-transparent bg-clip-text bg-gradient-to-r from-amber-600 to-amber-400">Библиотека</span>
			</h1>
			<p class="text-xl lg:text-2xl text-slate-600 dark:text-slate-300 max-w-2xl mx-auto leading-relaxed font-medium" style="font-family: var(--font-inter);">
				Современное многоязычное пространство для изучения трудов Бедиуззамана Саида Нурси.
			</p>
		</div>

		<HomePersistence client:only="react" />
		<!-- Dynamically passing all available languages inside libraryData -->
		<LibraryTabs client:only="react" library={libraryData} />
	</div>
</ReaderLayout>
