---
import { getCollection } from 'astro:content';
import ReaderLayout from '../layouts/ReaderLayout.astro';

// Filter for tr/ entries and get unique book names
const allEntries = await getCollection('risale');
const trEntries = allEntries.filter(entry => entry.slug.startsWith('tr/'));

// Sort and categorize
const books = trEntries.map(entry => ({
  slug: entry.data.book,
  title: entry.data.title
})).sort((a, b) => a.slug.localeCompare(b.slug));

// Separate main Risale books from others
const mainBooksSlugs = ['sozler', 'mektubat', 'lemalar', 'sualar', 'asamusa', 'tarihce', 'barla', 'kastamonu', 'emirdag1', 'emirdag2', 'sikke', 'muhakemat', 'mesnevi', 'isarat', 'imankufur'];
const mainBooks = books.filter(b => mainBooksSlugs.includes(b.slug));
const otherBooks = books.filter(b => !mainBooksSlugs.includes(b.slug));

// Pretty names mapping
const bookTitles = {
  'lemalar': 'Lem\'alar',
  'isarat': 'İşaratü\'l-İ\'caz',
  'mesnevi': 'Mesnevî-i Nuriye',
  'sozler': 'Sözler',
  'mektubat': 'Mektubat',
  'sualar': 'Şualar',
  'asamusa': 'Asâ-yı Musa',
  'tarihce': 'Tarihçe-i Hayatı',
  'barla': 'Barla Lâhikası',
  'kastamonu': 'Kastamonu Lâhikası',
  'emirdag1': 'Emirdağ Lâhikası 1',
  'emirdag2': 'Emirdağ Lâhikası 2',
  'sikke': 'Sikke-i Tasdik-i Gaybî',
  'muhakemat': 'Muhakemat',
  'imankufur': 'Asâ-yı Musa (İman-Küfür)',
  'kuranmeal': 'Kur\'an-ı Kerim Meali',
  'kuran': 'Kur\'an-ı Kerim',
  'cevsen': 'Cevşen-ül Kebir',
  'tesbihat': 'Namaz Tesbihatı',
  'abed': 'Âsâr-ı Bediiye',
  'hizbkuran': 'Hizb-ül Kur\'an',
  'hizbulhakaik': 'Hizb-ül Hakaik',
};

const getPrettyTitle = (slug, fallback) => bookTitles[slug] || fallback;

const title = "Электронная библиотека Рисале-и Нур";
---

<ReaderLayout title={title}>
	<div class="max-w-7xl mx-auto py-12 lg:py-20">
		<div class="text-center mb-16 lg:mb-24">
			<h1 class="text-6xl lg:text-8xl font-black text-slate-800 dark:text-white mb-8 tracking-tighter leading-none">
				Рисале-и Нур <br/><span class="text-amber-600 underline decoration-amber-200 underline-offset-[12px]">Библиотека</span>
			</h1>
			<p class="text-xl text-slate-500 dark:text-slate-400 max-w-2xl mx-auto leading-relaxed font-reader">
				Современное пространство для изучения трудов Бедиуззамана Саида Нурси. Поддержка интерактивых примечаний и переводов Корана.
			</p>
		</div>
		
		<div class="space-y-32">
			<!-- Main Külliyat Section -->
			<section>
				<h2 class="text-3xl font-black text-slate-800 dark:text-slate-100 mb-12 border-l-8 border-amber-500 pl-6 uppercase tracking-widest flex items-center gap-4">
          <span class="w-12 h-1 bg-amber-500"></span>
          Risale-i Nur Külliyatı
        </h2>
				<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-6">
					{mainBooks.map(book => (
            <a href={`/risale-library/tr/${book.slug}`} class="group p-6 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-3xl hover:border-amber-500 transition-all hover:-translate-y-1 shadow-sm">
              <div class="text-[9px] text-amber-600 font-bold uppercase tracking-widest mb-2 opacity-50">Kitap</div>
              <h4 class="text-lg font-bold text-slate-800 dark:text-slate-100 group-hover:text-amber-600 transition-colors leading-tight">
                {getPrettyTitle(book.slug, book.title)}
              </h4>
              <div class="mt-4 flex items-center justify-between opacity-0 group-hover:opacity-100 transition-opacity">
                <span class="text-[10px] text-slate-400 italic">Oku</span>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </div>
            </a>
          ))}
				</div>
			</section>

			<!-- Other Works Section -->
			<section>
				<h2 class="text-3xl font-black text-slate-800 dark:text-slate-100 mb-12 border-r-8 border-slate-400 pr-6 uppercase tracking-widest text-right flex items-center justify-end gap-4">
          Diğer Eserler
          <span class="w-12 h-1 bg-slate-400"></span>
        </h2>
				<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-6">
					{otherBooks.map(book => (
            <a href={`/risale-library/tr/${book.slug}`} class="group p-6 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-3xl hover:border-slate-500 transition-all hover:-translate-y-1 shadow-sm">
              <div class="text-[9px] text-slate-400 font-bold uppercase tracking-widest mb-2 opacity-50">Eser</div>
              <h4 class="text-lg font-bold text-slate-800 dark:text-slate-100 group-hover:text-slate-600 transition-colors leading-tight">
                {getPrettyTitle(book.slug, book.title)}
              </h4>
              <div class="mt-4 flex items-center justify-between opacity-0 group-hover:opacity-100 transition-opacity">
                <span class="text-[10px] text-slate-400 italic">Oku</span>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </div>
            </a>
          ))}
				</div>
			</section>
		</div>
	</div>
</ReaderLayout>
