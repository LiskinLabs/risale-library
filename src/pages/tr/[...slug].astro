---
import { getCollection } from 'astro:content';
import ReaderLayout from '../../layouts/ReaderLayout.astro';

export async function getStaticPaths() {
  const risaleEntries = await getCollection('risale', ({ id, data }) => {
    return id.startsWith('tr/') && data.book;
  });
  return risaleEntries.map(entry => {
    // entry.slug: "tr/sozler/01" -> we want the dynamic slug to be "sozler/01"
    const slug = entry.slug.replace('tr/', '');
    return {
      params: { slug },
      props: { entry },
    };
  });
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const bookTitles = {
  'lem-alar': 'Lem\'alar',
  'isaratu-l-i-caz': 'İşaratü\'l-İ\'caz',
  'nur-un-ilk-kapisi': 'Nur\'un İlk Kapısı',
  'mesnevi-i-nuriye': 'Mesnevî-i Nuriye',
  'munazarat': 'Münazarat',
  'muhakemat': 'Muhakemat',
  'sozler': 'Sözler',
  'mektubat': 'Mektubat',
  'sualar': 'Şualar',
  'asa-yi-musa': 'Asâ-yı Musa',
  'tarihce-i-hayati': 'Tarihçe-i Hayatı',
};

// Robust book name extraction
const bookName = entry.data.book || entry.slug.split('/')[1] || 'unknown';
const bookTitle = bookTitles[bookName] || bookName.replace(/-/g, ' ').replace(/\b\w/g, l => l.toUpperCase());

// Get all chapters for this book for the TOC
const allEntries = await getCollection('risale');
const bookChapters = allEntries
  .filter(e => e.data.book === bookName && e.slug.startsWith('tr/'))
  .sort((a, b) => (a.data.chapter || 0) - (b.data.chapter || 0));

// Get all books for the sidebar
const otherBooks = [...new Set(allEntries.filter(e => e.slug.startsWith('tr/') && e.data.book).map(e => e.data.book))]
  .filter(b => b !== bookName)
  .sort();

const currentIndex = bookChapters.findIndex(c => c.id === entry.id);
const prevChapter = currentIndex > 0 ? bookChapters[currentIndex - 1] : null;
const nextChapter = currentIndex < bookChapters.length - 1 ? bookChapters[currentIndex + 1] : null;

const getPrettyTitle = (slug) => bookTitles[slug] || slug.replace(/-/g, ' ').replace(/\b\w/g, l => l.toUpperCase());
---

<ReaderLayout title={`${entry.data.title} | ${bookTitle}`}>
  <div class="flex flex-col lg:flex-row gap-12 max-w-7xl mx-auto">
    <!-- Sidebar: TOC and Other Books -->
    <aside class="lg:w-72 flex-shrink-0">
      <div class="sticky top-24 space-y-10 max-h-[calc(100vh-8rem)] overflow-y-auto pr-4 scrollbar-thin">
        
        <!-- TOC Section -->
        <div>
          <h3 class="text-[10px] font-bold text-amber-600 uppercase tracking-[0.2em] mb-4 flex items-center gap-2">
            <span class="w-4 h-px bg-amber-600"></span>
            İçindekiler
          </h3>
          <nav class="space-y-1">
            {bookChapters.map(chapter => {
              const chapterSlug = chapter.slug.replace('tr/', '');
              const isActive = chapter.id === entry.id;
              return (
                <a 
                  href={`/risale-library/tr/${chapterSlug}`} 
                  class={`block text-xs py-2 px-3 rounded-lg transition-all ${
                    isActive 
                      ? 'bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400 font-bold' 
                      : 'text-slate-500 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 hover:text-slate-900 dark:hover:text-slate-100'
                  }`}
                >
                  {chapter.data.title}
                </a>
              );
            })}
          </nav>
        </div>

        <!-- Other Books Section -->
        <div>
          <h3 class="text-[10px] font-bold text-slate-400 dark:text-slate-600 uppercase tracking-[0.2em] mb-4 flex items-center gap-2">
            <span class="w-4 h-px bg-slate-400 dark:bg-slate-600"></span>
            Diğer Kitaplar
          </h3>
          <nav class="space-y-1">
            {otherBooks.map(book => (
              <a 
                href={`/risale-library/tr/${book}/01`} 
                class="block text-[11px] py-2 px-3 text-slate-500 dark:text-slate-500 hover:text-amber-600 transition-colors"
              >
                {getPrettyTitle(book)}
              </a>
            ))}
          </nav>
        </div>

      </div>
    </aside>

    <!-- Main Content -->
    <div class="flex-grow max-w-4xl">
      <div class="mb-12">
        <div class="inline-block px-4 py-1.5 rounded-full bg-amber-100 dark:bg-amber-900/30 text-amber-600 text-[10px] font-bold uppercase tracking-widest mb-4">
          {bookTitle} (Latin Türkçe)
        </div>
        <h1 class="text-4xl md:text-5xl font-black text-slate-800 dark:text-white mb-4 tracking-tighter leading-tight">
          {entry.data.title}
        </h1>
      </div>
      
      <article class="prose-risale dark:prose-invert font-reader leading-relaxed">
        <Content />
      </article>

      <!-- Navigation Footer -->
      <div class="mt-20 pt-8 border-t border-slate-200 dark:border-slate-800 flex flex-col sm:flex-row justify-between items-center gap-6 text-sm">
        <div class="w-full sm:w-auto">
          {prevChapter && (
            <a href={`/risale-library/tr/${prevChapter.slug.replace('tr/', '')}`} class="group flex flex-col gap-1 items-start text-slate-500 hover:text-amber-600 transition-colors">
              <span class="text-[10px] uppercase tracking-widest opacity-50">Önceki</span>
              <span class="font-bold flex items-center gap-2 group-hover:-translate-x-1 transition-transform">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                </svg>
                {prevChapter.data.title}
              </span>
            </a>
          )}
        </div>

        <a href="/risale-library/" class="p-2 text-slate-400 hover:text-amber-600 transition-colors" title="Ana Sayfa">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
          </svg>
        </a>

        <div class="w-full sm:w-auto text-right">
          {nextChapter && (
            <a href={`/risale-library/tr/${nextChapter.slug.replace('tr/', '')}`} class="group flex flex-col gap-1 items-end text-slate-500 hover:text-amber-600 transition-colors">
              <span class="text-[10px] uppercase tracking-widest opacity-50">Sonraki</span>
              <span class="font-bold flex items-center gap-2 group-hover:translate-x-1 transition-transform">
                {nextChapter.data.title}
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                </svg>
              </span>
            </a>
          )}
        </div>
      </div>
    </div>
  </div>
</ReaderLayout>
