---
import { getCollection } from 'astro:content';
import ReaderLayout from '../../layouts/ReaderLayout.astro';

export async function getStaticPaths() {
  const trEntries = await getCollection('risale', ({ id }) => id.startsWith('tr/'));
  return trEntries.map(entry => ({
    params: { book: entry.data.book },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await entry.render();

const allEntries = await getCollection('risale');
const trEntries = allEntries.filter(e => e.slug.startsWith('tr/') && e.data.book);

// Categorize books for sidebar
const mainBooksSlugs = ['sozler', 'mektubat', 'lemalar', 'sualar', 'asamusa', 'tarihce', 'barla', 'kastamonu', 'emirdag1', 'emirdag2', 'sikke', 'muhakemat', 'mesnevi', 'isarat', 'imankufur'];
const mainBooks = trEntries.filter(e => mainBooksSlugs.includes(e.data.book)).sort((a, b) => a.data.book.localeCompare(b.data.book));
const otherBooks = trEntries.filter(e => !mainBooksSlugs.includes(e.data.book)).sort((a, b) => a.data.book.localeCompare(b.data.book));

const bookTitles = {
  'lemalar': 'Lem\'alar',
  'isarat': 'İşaratü\'l-İ\'caz',
  'mesnevi': 'Mesnevî-i Nuriye',
  'sozler': 'Sözler',
  'mektubat': 'Mektubat',
  'sualar': 'Şualar',
  'asamusa': 'Asâ-yı Musa',
  'tarihce': 'Tarihçe-i Hayatı',
  'barla': 'Barla Lâhikası',
  'kastamonu': 'Kastamonu Lâhikası',
  'emirdag1': 'Emirdağ Lâhikası 1',
  'emirdag2': 'Emirdağ Lâhikası 2',
  'sikke': 'Sikke-i Tasdik-i Gaybî',
  'muhakemat': 'Muhakemat',
  'imankufur': 'Asâ-yı Musa (İman-Küfür)',
  'kuranmeal': 'Kur\'an-ı Kerim Meali',
  'kuran': 'Kur\'an-ı Kerim',
  'cevsen': 'Cevşen-ül Kebir',
  'tesbihat': 'Namaz Tesbihatı',
  'abed': 'Âsâr-ı Bediiye',
  'hizbkuran': 'Hizb-ül Kur\'an',
  'hizbulhakaik': 'Hizb-ül Hakaik',
};

const getPrettyTitle = (slug, fallback) => bookTitles[slug] || fallback;
---

<ReaderLayout title={`${getPrettyTitle(entry.data.book, entry.data.title)} | Рисале-и Нур`}>
  <div class="flex flex-col lg:flex-row gap-8 max-w-[1600px] mx-auto px-4">
    
    <!-- Left Sidebar: Library Navigation -->
    <aside class="hidden xl:block w-64 flex-shrink-0">
      <div class="sticky top-24 space-y-8 max-h-[calc(100vh-8rem)] overflow-y-auto pr-4 scrollbar-thin">
        <div>
          <h3 class="text-[10px] font-bold text-amber-600 uppercase tracking-widest mb-4">Külliyat</h3>
          <nav class="space-y-1">
            {mainBooks.map(book => (
              <a 
                href={`/risale-library/tr/${book.data.book}`} 
                class={`block text-[11px] py-1.5 px-3 rounded-lg transition-colors ${
                  book.data.book === entry.data.book 
                    ? 'bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400 font-bold' 
                    : 'text-slate-500 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 hover:text-slate-900 dark:hover:text-slate-100'
                }`}
              >
                {getPrettyTitle(book.data.book, book.data.title)}
              </a>
            ))}
          </nav>
        </div>

        <div>
          <h3 class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-4">Diğer Eserler</h3>
          <nav class="space-y-1">
            {otherBooks.map(book => (
              <a 
                href={`/risale-library/tr/${book.data.book}`} 
                class={`block text-[11px] py-1.5 px-3 rounded-lg transition-colors ${
                  book.data.book === entry.data.book 
                    ? 'bg-slate-200 dark:bg-slate-800 text-slate-900 dark:text-white font-bold' 
                    : 'text-slate-500 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 hover:text-slate-900 dark:hover:text-slate-100'
                }`}
              >
                {getPrettyTitle(book.data.book, book.data.title)}
              </a>
            ))}
          </nav>
        </div>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="flex-grow max-w-4xl bg-white dark:bg-slate-900 shadow-xl shadow-slate-200/50 dark:shadow-none rounded-3xl p-8 md:p-12 min-h-screen">
      <div class="mb-12 border-b border-slate-100 dark:border-slate-800 pb-8 text-center">
        <h1 class="text-5xl font-black text-slate-800 dark:text-white mb-4 tracking-tighter">
          {getPrettyTitle(entry.data.book, entry.data.title)}
        </h1>
        <div class="flex items-center justify-center gap-4 text-sm text-slate-400">
          <span class="px-3 py-1 bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400 rounded-full font-bold uppercase text-[10px]">Latin Türkçe</span>
          <span>Полное издание</span>
        </div>
      </div>

      <article id="book-content" class="prose-risale dark:prose-invert font-reader leading-relaxed max-w-none">
        <Content />
      </article>
    </main>

    <!-- Right Sidebar: Interactive TOC -->
    <aside class="lg:w-80 flex-shrink-0">
      <div class="sticky top-24 max-h-[calc(100vh-8rem)] overflow-y-auto pr-4 scrollbar-thin">
        <h3 class="text-[10px] font-bold text-amber-600 uppercase tracking-[0.2em] mb-6 flex items-center gap-2">
          <span class="w-4 h-px bg-amber-600"></span>
          Оглавление
        </h3>
        <nav class="space-y-0.5" id="toc-nav">
          {headings.map(h => (
            <a 
              href={`#${h.slug}`} 
              class={`block py-1.5 px-3 text-xs rounded-lg transition-all border-l-2 border-transparent hover:bg-amber-50 dark:hover:bg-amber-900/20 ${
                h.depth === 1 ? 'font-bold text-slate-800 dark:text-slate-200 mt-4' : 
                h.depth === 2 ? 'pl-6 text-slate-600 dark:text-slate-400' : 
                'pl-9 text-slate-500 dark:text-slate-500 italic'
              }`}
            >
              {h.text}
            </a>
          ))}
        </nav>
      </div>
    </aside>
  </div>

  <!-- Footnote Popup System -->
  <div id="footnote-popup" class="fixed bottom-8 left-1/2 -translate-x-1/2 max-w-lg w-[90%] bg-white dark:bg-slate-800 border-t-4 border-amber-500 shadow-2xl p-6 rounded-2xl hidden z-50 transform transition-all duration-300 translate-y-10 opacity-0">
    <div class="flex justify-between items-start mb-4">
      <span class="text-[10px] font-bold text-amber-600 uppercase tracking-widest">Примечание</span>
      <button id="close-footnote" class="p-1 hover:bg-slate-100 dark:hover:bg-slate-700 rounded-lg">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    <div id="footnote-content" class="text-sm text-slate-600 dark:text-slate-300 leading-relaxed font-reader"></div>
  </div>

  <!-- Tooltip System for Quran Translations -->
  <div id="quran-tooltip" class="fixed max-w-sm w-[90%] bg-slate-800 dark:bg-slate-700 text-white text-xs rounded-xl shadow-2xl p-4 z-[100] hidden transform transition-all duration-200 pointer-events-none">
    <span class="block font-bold text-amber-400 mb-1">Перевод:</span>
    <div id="quran-tooltip-content" class="leading-relaxed"></div>
  </div>

</ReaderLayout>

<script>
  // Quran Tooltip Logic
  const quranTooltip = document.getElementById('quran-tooltip');
  const quranTooltipContent = document.getElementById('quran-tooltip-content');
  let tooltipTimeout;

  document.querySelectorAll('.quran-text[data-translation]').forEach(el => {
    el.addEventListener('mouseenter', (e) => {
      clearTimeout(tooltipTimeout);
      const translation = el.getAttribute('data-translation');
      if (translation && quranTooltipContent && quranTooltip) {
        quranTooltipContent.innerHTML = translation;
        quranTooltip.classList.remove('hidden');
        
        // Positioning
        const rect = el.getBoundingClientRect();
        const tooltipRect = quranTooltip.getBoundingClientRect();
        
        let top = rect.top - tooltipRect.height - 10;
        let left = rect.left + (rect.width / 2) - (tooltipRect.width / 2);
        
        // Prevent going off screen
        if (top < 10) top = rect.bottom + 10;
        if (left < 10) left = 10;
        if (left + tooltipRect.width > window.innerWidth - 10) left = window.innerWidth - tooltipRect.width - 10;
        
        quranTooltip.style.top = `${top}px`;
        quranTooltip.style.left = `${left}px`;
        
        // Animate in
        requestAnimationFrame(() => {
          quranTooltip.classList.remove('opacity-0', 'scale-95');
          quranTooltip.classList.add('opacity-100', 'scale-100');
        });
      }
    });

    el.addEventListener('mouseleave', () => {
      if (quranTooltip) {
        quranTooltip.classList.remove('opacity-100', 'scale-100');
        quranTooltip.classList.add('opacity-0', 'scale-95');
        tooltipTimeout = setTimeout(() => {
          quranTooltip.classList.add('hidden');
        }, 200);
      }
    });
  });

  // Intercept Footnote Clicks
  const content = document.getElementById('book-content');
  const popup = document.getElementById('footnote-popup');
  const popupContent = document.getElementById('footnote-content');
  const closeBtn = document.getElementById('close-footnote');

  if (content) {
    content.addEventListener('click', (e) => {
      const target = e.target.closest('a');
      if (target && (target.hash.includes('fn') || target.id.includes('fnref'))) {
        e.preventDefault();
        const noteId = target.hash.substring(1);
        const noteElement = document.getElementById(noteId);
        
        if (noteElement) {
          popupContent.innerHTML = noteElement.innerHTML;
          const backlink = popupContent.querySelector('.footnote-backref');
          if (backlink) backlink.remove();
          
          popup.classList.remove('hidden');
          setTimeout(() => {
            popup.classList.remove('translate-y-10', 'opacity-0');
          }, 10);
        }
      }
    });
  }

  closeBtn?.addEventListener('click', () => {
    popup?.classList.add('translate-y-10', 'opacity-0');
    setTimeout(() => {
      popup?.classList.add('hidden');
    }, 300);
  });

  // Active heading highlighting
  // ⚡ Bolt Optimization: Cache active link and use O(1) attribute selector instead of O(N) querySelectorAll loop on scroll
  const observerOptions = {
    root: null,
    rootMargin: '0px 0px -80% 0px',
    threshold: 0
  };

  let activeLink = null;
  const activeClasses = ['text-amber-600', 'border-amber-500', 'bg-amber-50', 'dark:bg-amber-900/20'];

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const id = entry.target.getAttribute('id');
        const targetLink = document.querySelector(`#toc-nav a[href="#${id}"]`);

        if (targetLink && targetLink !== activeLink) {
          // Remove active classes from previous link
          if (activeLink) {
            activeLink.classList.remove(...activeClasses);
          }

          // Add active classes to new target link
          targetLink.classList.add(...activeClasses);
          activeLink = targetLink;
        }
      }
    });
  }, observerOptions);

  document.querySelectorAll('h1, h2, h3, h4').forEach(h => observer.observe(h));
</script>

<style is:global>
  .scrollbar-thin::-webkit-scrollbar { width: 4px; }
  .scrollbar-thin::-webkit-scrollbar-track { background: transparent; }
  .scrollbar-thin::-webkit-scrollbar-thumb { background-color: #e2e8f0; border-radius: 9999px; }
  .dark .scrollbar-thin::-webkit-scrollbar-thumb { background-color: #1e293b; }
  html { scroll-behavior: smooth; }
  .footnotes { margin-top: 5rem; padding-top: 2rem; border-top: 1px solid #f1f5f9; color: #94a3b8; font-size: 0.75rem; }
  .dark .footnotes { border-top-color: #1e293b; }
  .footnotes hr { display: none; }
  a[data-footnote-ref] { color: #d97706; font-weight: bold; text-decoration: none; padding: 0 0.125rem; }
  a[data-footnote-ref]:hover { text-decoration: underline; }
</style>
