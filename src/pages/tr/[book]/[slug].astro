---
import { getCollection } from 'astro:content';
import ReaderLayout from '../../../layouts/ReaderLayout.astro';

export async function getStaticPaths() {
  const risaleEntries = await getCollection('risale');
  return risaleEntries.map(entry => {
    const parts = entry.slug.split('/');
    // slug example: "tr/sozler/01" -> book="sozler", slug="01"
    const book = parts[1];
    const slug = parts[2];
    return {
      params: { book, slug },
      props: { entry },
    };
  });
}

const { entry } = Astro.props;
const { Content } = await entry.render();

// Map book slugs to pretty titles
const bookTitles = {
  'sozler': 'Sözler',
  'mektubat': 'Mektubat',
  'lemalar': 'Lem\'alar',
  'sualar': 'Şualar',
  'asayi-musa': 'Asâ-yı Musa',
  // etc.
};
const bookTitle = bookTitles[entry.data.book] || entry.data.book;
---

<ReaderLayout title={`${entry.data.title} | ${bookTitle}`}>
  <div class="max-w-4xl mx-auto py-8">
    <div class="mb-12 text-center">
      <div class="inline-block px-4 py-1.5 rounded-full bg-amber-100 dark:bg-amber-900/30 text-amber-600 text-[10px] font-bold uppercase tracking-widest mb-4">
        {bookTitle} (Latin Türkçe)
      </div>
      <h1 class="text-5xl font-black text-slate-800 dark:text-white mb-4 tracking-tighter">
        {entry.data.title}
      </h1>
    </div>
    
    <article class="prose-risale dark:prose-invert font-reader leading-relaxed">
      <Content />
    </article>

    <div class="mt-20 pt-8 border-t border-slate-200 dark:border-slate-800 flex justify-between items-center text-sm text-slate-500">
       <a href="/" class="hover:text-amber-600 transition-colors flex items-center gap-2">
         <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
           <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
         </svg>
         Главная
       </a>
    </div>
  </div>
</ReaderLayout>
