+  useEffect(() => {
+    if (!ids) return;
+    const loadBookSeoData = async () => {
+      // Basic dynamic SEO metadata from the first id
+      const idArray = ids.split(',');
+      const bookId = idArray[0];
+      const library = useLibraryStore.getState().library;
+      const book = library.find(b => b.hash === bookId);
+      
+      if (book) {
+        setSeoData({
+          title: `${book.title} - Risale Digital Library`,
+          description: book.metadata?.description || `Read ${book.title} ${book.author ? `by ${book.author}` : ''} on Risale Digital Library`,
+          image: book.coverImageUrl || 'https://cdn.readest.com/images/open_graph_preview_read_now.png'
+        });
+      }
+    };
+    loadBookSeoData();
+  }, [ids]);
+
   return (
-    <CSPostHogProvider>
-      <EnvProvider>
-        <AuthProvider>
-          <SyncProvider>
-            <Reader ids={ids} />
-          </SyncProvider>
-        </AuthProvider>
-      </EnvProvider>
